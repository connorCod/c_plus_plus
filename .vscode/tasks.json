{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: build active file",
            "command": "/usr/bin/clang++",
            "args": [
                "-fcolor-diagnostics", "-fansi-escape-codes",
                "-g", "-Wall", "-Weffc++", "-Wextra",
                "-Wconversion", "-Wsign-conversion",
                "${file}",
                "-o", "${workspaceFolder}/build/${fileBasenameNoExtension}"
            ],
            "options": { "cwd": "${fileDirname}" },
            "problemMatcher": ["$gcc"],
            "group": { "kind": "build", "isDefault": true }
        },
        {
            "type": "cppbuild",
            "label": "C/C++: build folder of active file",
            "command": "/usr/bin/clang++",
            "args": [
                "-fcolor-diagnostics", "-fansi-escape-codes",
                "-g", "-Wall", "-Weffc++", "-Wextra",
                "-Wconversion", "-Wsign-conversion",
                "${fileDirname}/*.cpp",
                "-o", "${workspaceFolder}/build/${fileDirnameBasename}"
            ],
            "options": { "cwd": "${fileDirname}" },
            "problemMatcher": ["$gcc"],
            "group": "build"
        }
    ]
}
